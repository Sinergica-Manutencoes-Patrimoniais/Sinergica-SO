# =============================================================================
# Sinérgica OS — Variáveis de ambiente
# Copie para .env.local e preencha os valores reais.
# NUNCA commite chaves reais. Ver seguranca/baseline-minimo.md.
# =============================================================================

# --- Supabase (Públicas — client) ---
VITE_SUPABASE_URL=https://<project>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon_key>

# --- Supabase (Servidor — Edge Functions / scripts) ---
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# --- Supabase (CLI local — `supabase link`/`db push` direto, só emergência) ---
SUPABASE_ACCESS_TOKEN=sbp_<personal_access_token>
SUPABASE_PROJECT_ID=<project_ref>
SUPABASE_DB_PASSWORD=<db_password>

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=https://<sua-instancia-evolution>/
EVOLUTION_API_KEY=<api_key>
EVOLUTION_HMAC_SECRET=<hmac_secret_minimo_32_chars>

# --- Meta Graph API (WhatsApp Cloud, Instagram e Messenger) ---
META_ACCESS_TOKEN=<system_user_access_token>
META_APP_SECRET=<meta_app_secret>
META_GRAPH_VERSION=v22.0

# --- OpenRouter (LLM) ---
OPENROUTER_API_KEY=<openrouter_api_key>
OPENROUTER_ZE_MODEL=google/gemini-2.5-flash
ZE_SYSTEM_USER_ID=<uuid_usuario_sistema_ze>

# --- Auvo (App de campo) ---
AUVO_API_KEY=<auvo_api_key>
AUVO_USER_TOKEN=<auvo_user_token>

# --- Geral ---
CORS_ALLOWED_ORIGINS=https://sinergica.netlify.app
