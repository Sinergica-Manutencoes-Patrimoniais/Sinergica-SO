{
  "name": "sinergica-os",
  "private": true,
  "version": "0.1.0",
  "description": "Sinérgica OS — sistema operacional da Sinérgica Manutenções (monorepo, Padrão OS v2).",
  "packageManager": "pnpm@9.0.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "prepare": "husky",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "audit:esteira": "node scripts/audit-esteira.mjs",
    "eval:spec": "node scripts/eval-spec-fidelity.mjs",
    "audit:deps": "pnpm audit --prod --audit-level=high"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.3.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "turbo": "^2.1.0",
    "typescript": "^5.6.0"
  }
}
